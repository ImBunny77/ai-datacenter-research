# ============================================================
# 1GW AI Data Center - Base Assumptions (Edit freely)
# ============================================================

# --- Datacenter Scale ---
DATACENTER_POWER_MW=1000          # Total MW capacity
RACK_DENSITY_KW=40                # kW per rack
GPUS_PER_RACK=8                   # NVIDIA H100/H200 per rack
GPU_UNIT_COST_USD=30000           # $/GPU (Blackwell B200 ~$30-40k)

# --- Power Costs ---
POWER_COST_PER_KWH=0.045          # $/kWh base rate (datacenter wholesale)
PUE=1.35                          # Power Usage Effectiveness (1.0=perfect, 1.2=great, 1.5=poor)

# --- Capital Expenditure ---
COOLING_CAPEX_PER_MW=2500000      # $/MW for liquid cooling infrastructure
BUILDING_CAPEX_PER_MW=1500000     # $/MW for shell, power, networking
DEPRECIATION_YEARS=5              # Straight-line depreciation schedule

# --- Revenue Assumptions ---
GPU_RENTAL_PRICE_PER_HOUR=2.80    # $/GPU/hr base (H100 spot ~$2-4, Blackwell ~$4-6)
UTILIZATION_RATE=0.85             # % of GPU fleet generating revenue
CONTRACT_REVENUE_FRACTION=0.70    # % locked in long-term contracts vs spot

# --- Monte Carlo Settings ---
MC_SIMULATIONS=10000
MC_RANDOM_SEED=42
SIMULATION_YEARS=5

# --- Stress Test Ranges (% deviation from base) ---
POWER_COST_STD_PCT=0.25           # +/- 25% power cost volatility
DOWNTIME_MEAN_PCT=0.05            # 5% average downtime
DOWNTIME_STD_PCT=0.04             # Downtime standard deviation
GPU_PRICE_COMPRESSION_PCT_PER_YR=0.12   # 12%/yr rental price compression
GPU_PRICE_COMPRESSION_STD=0.05    # Compression rate uncertainty

# --- Underwriting Threshold ---
TARGET_MULTIPLE=15.0              # 15x return on equity target
EQUITY_FRACTION=0.30              # % of CAPEX funded by equity (rest = debt)
DEBT_INTEREST_RATE=0.065          # 6.5% interest on debt
